bin/

# Python compiled / build artifacts (anywhere in the repo)
__pycache__/
*.py[cod]
*.egg-info/
.ruff_cache/
.pytest_cache/
build/
dist/

# Ignore dojo working dirs, except the committed golden plans that measure.sh
# runs from (frozen plans remove planner variance from measurement).
dojo/*
!dojo/golden/
dojo/golden/*/*
!dojo/golden/*/PLAN.md
# Exclude temporary main file for local testing
tmp_main.rs

# Ephemeral practice-loop and Claude harness state
.claude/
dojo-failures.md
practice_output.txt
