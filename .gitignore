bin/

# Python compiled / build artifacts (anywhere in the repo)
__pycache__/
*.py[cod]
*.egg-info/
.ruff_cache/
.pytest_cache/
build/
dist/

# Ignore dojo working dirs, except the committed golden plans (mu dojo measure) and
# fixtures (fixture mode — files given to the model to remove failure classes).
dojo/*
!dojo/golden/
dojo/golden/*/*
!dojo/golden/*/PLAN.md
!dojo/fixtures/
!dojo/fixtures/**
# Exclude temporary main file for local testing
tmp_main.rs

# Ephemeral practice-loop and Claude harness state
.claude/
dojo-failures.md
practice_output.txt
# Local collection-run state: logs, launcher, thermal/bench data, scan reports.
# Operational scratch under the repo's .mu/ — never source of truth.
.mu/
# Archive directories with session history
archive/
