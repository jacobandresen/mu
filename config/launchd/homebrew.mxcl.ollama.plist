<?xml version="1.0" encoding="UTF-8"?>
<!-- Install: cp config/launchd/homebrew.mxcl.ollama.plist ~/Library/LaunchAgents/ -->
<!--          Update HOME to your username, then:                                   -->
<!--          launchctl load ~/Library/LaunchAgents/homebrew.mxcl.ollama.plist     -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>homebrew.mxcl.ollama</string>
	<key>ProgramArguments</key>
	<array>
		<string>/opt/homebrew/opt/ollama/bin/ollama</string>
		<string>serve</string>
	</array>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>/Users/jacob</string>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
		<key>OLLAMA_FLASH_ATTENTION</key>
		<string>1</string>
		<key>OLLAMA_KV_CACHE_TYPE</key>
		<string>q8_0</string>
		<key>OLLAMA_SCHED_SPREAD</key>
		<string>1</string>
		<key>OLLAMA_NUM_PARALLEL</key>
		<string>1</string>
		<key>OLLAMA_CONTEXT_LENGTH</key>
		<string>4096</string>
		<key>OLLAMA_KEEP_ALIVE</key>
		<string>-1</string>
		<key>OLLAMA_MAX_QUEUE</key>
		<string>512</string>
		<key>OLLAMA_MAX_LOADED_MODELS</key>
		<string>1</string>
		<key>OLLAMA_NUM_THREADS</key>
		<string>8</string>
	</dict>
	<key>RunAtLoad</key>
	<true/>
	<key>KeepAlive</key>
	<true/>
	<key>LimitLoadToSessionType</key>
	<array>
		<string>Aqua</string>
		<string>Background</string>
		<string>LoginWindow</string>
		<string>StandardIO</string>
		<string>System</string>
	</array>
	<key>StandardOutPath</key>
	<string>/opt/homebrew/var/log/ollama.log</string>
	<key>StandardErrorPath</key>
	<string>/opt/homebrew/var/log/ollama.log</string>
	<key>WorkingDirectory</key>
	<string>/opt/homebrew/var</string>
</dict>
</plist>
